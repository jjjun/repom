{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🧪Pytest/benchmark",
      "type": "shell",
      "command": "uv run pytest --benchmark-columns=mean,rounds,iterations --benchmark-only -m run_benchmark",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "🧪Pytest/all",
      "type": "shell",
      "command": "uv run pytest --override-ini addopts='-q --tb=line -rfE --show-capture=no' -v -ra -W default tests/unit_tests tests/behavior_tests",
      "group": {
        "kind": "test",
      },
      "problemMatcher": [
        "$python",
        {
          "owner": "pytest-warnings",
          "severity": "warning",
          "pattern": [
            {
              "regexp": "^\\s*((?:[A-Za-z]:\\\\|/).+?):(\\d+):\\s+(.*Warning:.*)$",
              "file": 1,
              "line": 2,
              "message": 3
            }
          ]
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "🧪Pytest/unit_tests",
      "type": "shell",
      "command": "uv run pytest tests/unit_tests",
      "group": {
        "kind": "test",
      },
      "problemMatcher": []
    },
    {
      "label": "💾uv/db_sync_master",
      "type": "shell",
      "command": "uv run db_sync_master",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "💾uv/db_backup",
      "type": "shell",
      "command": "uv run db_backup",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "💾uv/db_create",
      "type": "shell",
      "command": "$env:EXEC_ENV='dev'; uv run db_create; $env:EXEC_ENV='prod'; uv run db_create",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "🔥uv/db_delete",
      "type": "shell",
      "command": "uv run db_delete",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "🤖uv/scaffold",
      "type": "shell",
      "command": "uv run scaffold",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "🧬Alembic/gen/migration_file",
      "type": "shell",
      "command": "uv run alembic revision --autogenerate -m 'comment'",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "🧬Alembic/migration/all",
      "type": "shell",
      "command": "$env:EXEC_ENV='dev'; uv run alembic upgrade head; $env:EXEC_ENV='prod'; uv run alembic upgrade head",
      "group": {
        "kind": "none",
      },
      "problemMatcher": []
    },
    {
      "label": "🔄merge/basekit",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update_basekit_rev.ps1",
      "group": {
        "kind": "none"
      },
      "problemMatcher": []
    },
    {
      "label": "issue: info",
      "type": "shell",
      "command": "issuekit info",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
  ]
}
