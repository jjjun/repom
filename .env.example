# Repom Configuration Example
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# .env is excluded from git. .env.example is committed as a reference.

# -----------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------

# Execution environment: dev | test | prod
EXEC_ENV=dev

# CONFIG_HOOK: dot-separated module path + colon + callable name.
# Used to inject project-specific configuration into repom.
# Uncomment and set this when using repom from an external project.
CONFIG_HOOK=repom.config_hook:hook_config
# CONFIG_HOOK=mine_py.config:get_repom_config

# -----------------------------------------------------------------------
# Database (SQLite — defaults, usually no change needed)
# -----------------------------------------------------------------------

# SQLITE_DB_PATH=data
# SQLITE_DB_FILE=app_dev.sqlite3
# SQLITE_USE_IN_MEMORY_FOR_TESTS=true

# -----------------------------------------------------------------------
# Database (PostgreSQL — set DB_TYPE=postgres to enable)
# -----------------------------------------------------------------------

# DB_TYPE=postgres
# REPOM_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/app_dev

# POSTGRES_USER=repom
# POSTGRES_PASSWORD=changeme
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------
# pgAdmin (optional, only used when PostgreSQL is enabled)
# -----------------------------------------------------------------------

# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=changeme

# -----------------------------------------------------------------------
# Redis (optional)
# -----------------------------------------------------------------------

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# -----------------------------------------------------------------------
# SQLAlchemy Diagnostics (optional)
# -----------------------------------------------------------------------

# SQLALCHEMY_ECHO=false
# SQLALCHEMY_ECHO_LEVEL=INFO
